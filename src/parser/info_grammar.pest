// Mermaid Info Diagram Grammar
// The simplest diagram type: just "info" with optional "showInfo" and title.

WHITESPACE = _{ " " | "\t" }

// Newline and comment
newline = _{ "\r"? ~ "\n" }
comment = _{ "%%" ~ (!newline ~ ANY)* }
line_end = _{ newline | EOI }

// Keywords
info_keyword = { ^"info" }
show_info = { ^"showInfo" }

// Title
title_keyword = _{ "title" }
title_text = @{ (!newline ~ ANY)+ }
title_stmt = { title_keyword ~ title_text }

// Lines that are blank or comments (skipped)
skip_line = _{ comment ~ line_end | newline }

// Complete info diagram
info_diagram = {
    SOI ~
    skip_line* ~
    info_keyword ~ line_end ~
    skip_line* ~
    (show_info ~ line_end ~ skip_line*)? ~
    (title_stmt ~ line_end ~ skip_line*)? ~
    EOI
}
