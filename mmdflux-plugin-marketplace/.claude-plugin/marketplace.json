{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "mmdflux-local",
  "owner": {
    "name": "mmdflux",
    "email": "kevin@swiber.dev"
  },
  "plugins": [
    {
      "name": "rust-analyzer-lsp",
      "source": "./plugins/rust-analyzer-lsp",
      "description": "Project rust-analyzer with architecture boundary checking via cargo xtask lint",
      "version": "1.0.0",
      "category": "development",
      "strict": false,
      "lspServers": {
        "rust": {
          "command": "rust-analyzer",
          "extensionToLanguage": { ".rs": "rust" },
          "initializationOptions": {
            "check": {
              "overrideCommand": ["cargo", "xtask", "lint", "--json"]
            }
          },
          "settings": {},
          "transport": "stdio"
        }
      }
    }
  ]
}
