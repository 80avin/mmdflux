{
  "name": "mmdflux-rust-lsp",
  "description": "Project rust-analyzer with architecture boundary checking via cargo xtask lint",
  "version": "1.0.0",
  "lspServers": {
    "rust": {
      "command": "rust-analyzer",
      "extensionToLanguage": { ".rs": "rust" },
      "initializationOptions": {
        "check": {
          "overrideCommand": ["cargo", "xtask", "lint", "--json"]
        }
      },
      "transport": "stdio",
      "settings": {},
      "maxRestarts": 3
    }
  }
}
